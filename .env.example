# .env — Copy this file to .env and fill in your credentials
# Never commit this file to version control

# ── Phemex ────────────────────────────────────────────────────────────────────
PHEMEX_API_KEY=your_phemex_api_key_here
PHEMEX_API_SECRET=your_phemex_api_secret_here

# ── XLTRADE / MT5 ─────────────────────────────────────────────────────────────
# Windows only — path to MT5 Common Files folder
# In MT5: File → Open Data Folder → go up one level → Common → Files
MT5_FILES_PATH=C:\Users\YourName\AppData\Roaming\MetaQuotes\Terminal\Common\Files

# ── Network Bridge (for Termux / remote use) ──────────────────────────────────
# On your Windows PC: run bridge.py, it will print the URL to use here.
# Leave blank when running copycat.py directly on Windows.
BRIDGE_URL=

# A shared secret between bridge.py (PC) and copycat.py (phone).
# Set to any random string — must match on both devices.
# Example: BRIDGE_TOKEN=bj_s3cr3t_2025
BRIDGE_TOKEN=

# Optional: change the port bridge.py listens on (default: 7373)
# BRIDGE_PORT=7373
